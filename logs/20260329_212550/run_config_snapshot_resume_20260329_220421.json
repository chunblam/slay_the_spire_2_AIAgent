{
  "device": "auto",
  "env": {
    "host": "127.0.0.1",
    "port": 18080,
    "character_index": 0,
    "startup_debug": false,
    "action_poll_interval": 0.8,
    "action_min_interval": 0.8,
    "post_action_settle": 0.8,
    "action_retry_count": 1,
    "num_actions": 16
  },
  "model": {
    "hidden_dim": 256,
    "card_d_model": 64,
    "monster_d_model": 32
  },
  "train": {
    "total_steps": 30000,
    "buffer_size": 256,
    "n_epochs": 3,
    "batch_size": 64,
    "lr": 0.0003,
    "clip_eps": 0.2,
    "value_loss_coef": 0.5,
    "entropy_coef": 0.01,
    "gamma": 0.99,
    "gae_lambda": 0.95,
    "save_interval": 5000,
    "resume_on_restart": true,
    "save_latest_per_update": true,
    "continue_logs_on_resume": true,
    "manual_intervention_max_wait": 180.0,
    "manual_intervention_poll": 0.5
  },
  "llm": {
    "enabled": false,
    "backend": "ollama",
    "model": "qwen2.5:7b",
    "base_url": "http://127.0.0.1:11434",
    "strategy": "balanced",
    "use_map_advisor": false,
    "use_combat_advisor": false,
    "use_relic_advisor": false,
    "use_card_advisor": false,
    "use_rest_advisor": false,
    "use_event_advisor": false,
    "top_k": 3,
    "temperature": 0.2,
    "match_bonus_coef": 0.8
  },
  "logging": {
    "level": "INFO",
    "tensorboard": true,
    "checkpoint_verbose": false
  },
  "reward": {
    "layer_a_weight": 1.0,
    "layer_b_weight": 1.0,
    "layer_c_weight": 1.0,
    "layer_d_weight": 0.3,
    "layer_e_weight": 1.0,
    "llm_weight": 0.3,
    "action_damage_coef": 0.004,
    "action_block_coef": 0.002,
    "action_card_pick_bonus": 0.05,
    "action_potion_bonus": 0.05,
    "dmg_reward_cap": 1.5,
    "kill_reward_per_enemy": 2.0,
    "block_coverage_reward": 1.0,
    "excess_block_penalty_cap": 0.2,
    "energy_waste_penalty": 0.5,
    "hp_loss_penalty": 1.5,
    "hp_loss_urgency_max_mul": 2.0,
    "normal_combat_bonus": 3.0,
    "elite_combat_bonus": 8.0,
    "boss_combat_bonus": 20.0,
    "boss_extra_bonus": 10.0,
    "hp_efficiency_max": 4.0,
    "elite_clean_bonus": 3.0,
    "elite_clean_threshold": 0.3,
    "rest_low_hp_bonus": 1.0,
    "rest_mid_hp_bonus": 0.3,
    "rest_high_hp_penalty": 0.5,
    "rest_low_threshold": 0.35,
    "rest_mid_threshold": 0.6,
    "rest_high_threshold": 0.8,
    "smith_bonus": 0.5,
    "remove_card_bonus": 0.4,
    "choose_card_meta_bonus": 0.3,
    "buy_bonus": 0.2,
    "terminal_victory_bonus": 100.0,
    "terminal_defeat_penalty": 30.0,
    "terminal_floor_weight": 1.5,
    "terminal_hp_quality_weight": 10.0,
    "reward_clip": 50.0,
    "card_weight": 0.4,
    "card_match_bonus": 1.0,
    "card_mismatch_penalty": 0.5,
    "relic_choice_weight": 0.25,
    "map_route_weight": 0.25,
    "combat_opening_weight": 0.2
  },
  "perf": {
    "num_workers": 0,
    "pin_memory": false,
    "prefetch_size": 2
  },
  "checkpoint_dir": "checkpoints",
  "render": false
}